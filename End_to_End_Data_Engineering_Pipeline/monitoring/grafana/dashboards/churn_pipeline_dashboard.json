{
  "dashboard": {
    "id": null,
    "title": "Churn Prediction Pipeline Dashboard",
    "tags": ["churn", "ml", "pipeline"],
    "style": "dark",
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Pipeline Status Overview",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(churn_dag_runs_total{status=\"success\"}[5m])",
            "refId": "A"
          },
          {
            "expr": "rate(churn_dag_runs_total{status=\"failed\"}[5m])",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "red", "value": 1}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Model Accuracy",
        "type": "gauge",
        "targets": [
          {
            "expr": "churn_model_accuracy",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.7},
                {"color": "green", "value": 0.8}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "DAG Run Duration",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(churn_dag_run_duration_seconds_bucket[5m]))",
            "refId": "A",
            "legendFormat": "95th percentile"
          },
          {
            "expr": "histogram_quantile(0.50, rate(churn_dag_run_duration_seconds_bucket[5m]))",
            "refId": "B", 
            "legendFormat": "50th percentile"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Customers at Risk",
        "type": "piechart",
        "targets": [
          {
            "expr": "churn_customers_at_risk",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "displayMode": "gradient"
            }
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16}
      },
      {
        "id": 5,
        "title": "Predictions Generated",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(churn_predictions_generated_total[5m])",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16}
      },
      {
        "id": 6,
        "title": "Data Quality Score",
        "type": "stat",
        "targets": [
          {
            "expr": "churn_data_quality_score",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.8},
                {"color": "green", "value": 0.9}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16}
      },
      {
        "id": 7,
        "title": "Kafka Message Throughput",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(churn_kafka_messages_produced_total[5m])",
            "refId": "A",
            "legendFormat": "Produced {{topic}}"
          },
          {
            "expr": "rate(churn_kafka_messages_consumed_total[5m])",
            "refId": "B",
            "legendFormat": "Consumed {{topic}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24}
      },
      {
        "id": 8,
        "title": "S3 Upload Performance",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(churn_s3_upload_duration_seconds_bucket[5m]))",
            "refId": "A",
            "legendFormat": "95th percentile duration"
          },
          {
            "expr": "rate(churn_s3_upload_errors_total[5m])",
            "refId": "B",
            "legendFormat": "Upload errors/sec"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24}
      },
      {
        "id": 9,
        "title": "Feature Importance",
        "type": "barchart",
        "targets": [
          {
            "expr": "topk(10, churn_model_feature_importance)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "orientation": "horizontal"
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32}
      },
      {
        "id": 10,
        "title": "System Resources",
        "type": "timeseries",
        "targets": [
          {
            "expr": "(1 - rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100",
            "refId": "A",
            "legendFormat": "CPU Usage %"
          },
          {
            "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
            "refId": "B",
            "legendFormat": "Memory Usage %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32}
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s"
  }
}